---
import type { FunFactsProps } from "../../types/strapi";

interface Props {
  data: FunFactsProps;
}

const {
  data: { title, listItem },
} = Astro.props;
---

<section>
  <div class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl font-bold text-center mb-8">{title}</h2>
      {listItem && listItem.length > 0 && (
        <ul class="max-w-2xl mx-auto space-y-4">
          {listItem.map((item) => (
            <li class="flex items-center gap-3 p-4 bg-white rounded-lg shadow-sm">
              <span class="w-2 h-2 bg-green-500 rounded-full"></span>
              <span>{item.text}</span>
            </li>
          ))}
        </ul>
      )}
    </div>
  </div>
</section>