---
import type { PlantGridProps } from "../../types/strapi";
import StrapiImage from "../StrapiImage.astro";

interface Props {
  data: PlantGridProps;
  locale?: string;
}

const {
  data: { plantCard },
  locale = 'hu',
} = Astro.props;

const labels = {
  hu: { watering: 'Vízigény', difficulty: 'Nehézség', light: 'Fényigény' },
  en: { watering: 'Watering', difficulty: 'Difficulty', light: 'Light' },
} as const;

const enumMap = {
  hu: {
    easy: 'Könnyű', medium: 'Közepes', hard: 'Nehéz',
    low: 'Alacsony', moderate: 'Közepes', high: 'Magas',
  },
  en: {
    easy: 'Easy', medium: 'Medium', hard: 'Hard',
    low: 'Low', moderate: 'Moderate', high: 'High',
  },
} as const;

const t = labels[locale as keyof typeof labels] ?? labels.hu;
const e = enumMap[locale as keyof typeof enumMap] ?? enumMap.hu;

function translateValue(value: string | null | undefined): string {
  if (!value) return '';
  return e[value as keyof typeof e] ?? value;
}
---

<section aria-labelledby="plants-heading">
  <div class="pt-12 pb-20 bg-gray-50">
    <div class="container mx-auto px-4">

      <h2 id="plants-heading" class="sr-only">
        Növények listája
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {plantCard &&
          plantCard.map((card) => {
            return (
              <article class="flex flex-col h-full">
                
                {card.image && (
                  <StrapiImage
                    image={card.image}
                    height={600}
                    width={800}
                    class="h-120 w-full object-cover rounded-3xl"
                  />
                )}

                <header>
                  <h3 class="mt-4 mb-2 text-2xl font-bold font-heading">
                    {card.title}
                  </h3>
                </header>

                <p class="text-gray-500 mb-4">
                  {card.description}
                </p>

                <dl class="mt-auto text-sm text-gray-600 space-y-1">
                  <div>
                    <dt class="font-semibold inline">{t.watering}: </dt>
                    <dd class="inline">
                      {translateValue(card.watering)}
                    </dd>
                  </div>

                  <div>
                    <dt class="font-semibold inline">{t.light}: </dt>
                    <dd class="inline">
                      {translateValue(card.light)}
                    </dd>
                  </div>

                  <div>
                    <dt class="font-semibold inline">{t.difficulty}: </dt>
                    <dd class="inline">
                      {translateValue(card.difficulity)}
                    </dd>
                  </div>
                </dl>

              </article>
            );
          })}
      </div>

    </div>
  </div>
</section>
