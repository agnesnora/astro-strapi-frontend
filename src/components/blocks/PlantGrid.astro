---
import type { PlantGridProps } from "../../types/strapi";
import StrapiImage from "../StrapiImage.astro";

interface Props {
  data: PlantGridProps;
  locale?: string;
}

const {
  data: { plantCard },
  locale = 'hu',
} = Astro.props;

const labels = {
  hu: { watering: 'Vízigény', difficulty: 'Nehézség', light: 'Fényigény' },
  en: { watering: 'Watering', difficulty: 'Difficulty', light: 'Light' },
} as const;

const enumMap = {
  hu: {
    easy: 'Könnyű', medium: 'Közepes', hard: 'Nehéz',
    low: 'Alacsony', moderate: 'Közepes', high: 'Magas',
  },
  en: {
    easy: 'Easy', medium: 'Medium', hard: 'Hard',
    low: 'Low', moderate: 'Moderate', high: 'High',
  },
} as const;

const t = labels[locale as keyof typeof labels] ?? labels.hu;
const e = enumMap[locale as keyof typeof enumMap] ?? enumMap.hu;

function translateValue(value: string | null | undefined): string {
  if (!value) return '';
  return e[value as keyof typeof e] ?? value;
}
---

<section>
  <div class="pt-12 pb-20 bg-gray-50">
    <div class="container mx-auto px-4">
      <div class="flex flex-wrap -mx-4">
{
  plantCard &&
    plantCard.map((card) => {
      return (
        <div class="mb-12 lg:mb-0 w-full md:w-1/2 lg:w-1/4 px-4">
            {card.image && (
              <StrapiImage image={card.image} height={600} width={800} class="h-128 w-full max-w-lg object-cover rounded-3xl md:rounded-br-none" />
            )}
            <h4 class="mb-4 text-2xl font-bold font-heading">
              {card.title}
            </h4>
            <p class="text-gray-500 leading-loose">{card.description}</p>
            <p class="text-gray-500 leading-loose"><strong>{t.watering}: </strong>{translateValue(card.watering)}</p>
            <p class="text-gray-500 leading-loose"><strong>{t.difficulty}: </strong>{translateValue(card.difficulity)}</p>
        </div>
      );
    })
}
      </div>
    </div>
  </div>
</section>
