---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getArticles,getArticleBySlug} from '../../../../lib/loader';
import StrapiImage from '../../../../components/StrapiImage.astro';
import { marked } from 'marked';
import type { Article } from '../../../../types/strapi';


const { slug } = Astro.params;
const lang = "en";

const article= await getArticleBySlug(slug, "en");



if (!article) {
  throw new Error("Plant not found");
}

export async function getStaticPaths() {
  const articles = await getArticles("en");

  console.log("EN ARTICLES:", articles.data.map(p=> p.slug));

  return articles.data?.map((plant: any) => ({
    params: { slug: plant.slug },
  }));
}


// const globalData = await getGlobalPageData();
const htmlContent = article.description ? marked(article.description) : '';
---

<BaseLayout locale="en">
  <article class="py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      
   
      <header class="mb-8">
        <h1 class="text-4xl font-bold mb-4">{article.name}</h1>
        <p class="text-gray-600 text-lg mb-4">{article.shortDescription}</p>
          <p class="text-gray-600 text-lg mb-4">{article.description}</p>
        
      
      </header>
      
   
      {article.featuredImage && (
        <StrapiImage 
          image={article.featuredImage} 
          class="w-full h-96 object-cover rounded-lg mb-8"
        />
      )}
      
     
      <div class="prose prose-lg max-w-none" set:html={htmlContent} />
      
    </div>
  </article>
</BaseLayout>