---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPlants } from '../../../lib/loader';
import StrapiImage from '../../../components/StrapiImage.astro';
import { localizeHref } from '../../../lib/i18n';

const locale = Astro.currentLocale ?? 'en';
const plantsData = await getPlants(locale);
const plants: any[] = plantsData.data || [];
---

<BaseLayout>
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold mb-8">Plants</h1>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {plants.map((plant) => (
          <a href={localizeHref(`/plants/${plant.slug}`, locale)} class="group">
            <plant class=" overflow-hidden shadow-sm hover:shadow-md transition">
              {plant.image && (
                <StrapiImage 
                  image={plant.image[0]} 
                  class="w-full h-120 object-cover mb-4"
                />
              )}
              <div >
                <h2 class="text-xl font-semibold group-hover:text-blue-600">
                  {plant.name}
                </h2>
                <p class="text-gray-600 mt-2">{plant.shortDescription}</p>
             
              </div>
            </plant>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>