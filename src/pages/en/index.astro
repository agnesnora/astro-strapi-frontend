---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BlockRenderer from "../../components/blocks/BlockRenderer.astro";

import { getLandingPageData } from "../../lib/loader";

const locale = Astro.currentLocale ?? 'hu';
const data = await getLandingPageData(locale);

const landingPage = data?.data;

if (!landingPage) throw new Error("Landing page not found");
---

<BaseLayout>
  <BlockRenderer blocks={landingPage.blocks} locale={locale} page={landingPage} />
</BaseLayout>