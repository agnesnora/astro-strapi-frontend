---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout>
  <section class="py-32">
    <div class="container mx-auto px-4 text-center">
      <p class="text-8xl font-bold text-green-500 mb-4">404</p>
      <h1 class="text-3xl font-bold text-gray-800 mb-4">Az oldal nem található</h1>
      <p class="text-gray-500 mb-10">A keresett oldal nem létezik, vagy áthelyezték.</p>
      <a
        href="/hu"
        class="py-3 px-8 bg-green-500 hover:bg-green-600 text-white font-bold rounded-l-xl rounded-t-xl transition duration-200"
      >
        Vissza a főoldalra
      </a>
    </div>
  </section>
</BaseLayout>
