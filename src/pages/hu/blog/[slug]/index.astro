---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getArticles, getArticleBySlug } from '../../../../lib/loader';
import StrapiImage from '../../../../components/StrapiImage.astro';
import { marked } from 'marked';
import type { Article } from '../../../../types/strapi';



export async function getStaticPaths() {
  const articles = await getArticles();

  return articles.data?.map((article: any) => ({
    params: { slug: article.slug },
  }));
}

const { slug } = Astro.params;
const locale = Astro.currentLocale ?? 'hu';

const article = await getArticleBySlug(slug, locale);

if (!article) {
  throw new Error("Article not found");
}


const htmlContent = article.content ? marked(article.content) : '';
---

<BaseLayout>
  <article class="py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      
   
      <header class="mb-8">
        <h1 class="text-4xl font-bold mb-4">{article.title}</h1>
        <p class="text-gray-600 text-lg mb-4">{article.description}</p>
        
     
        <div class="flex items-center gap-4">
          {article.author?.image && (
            <StrapiImage 
              image={article.author.image} 
              class="w-12 h-12 rounded-full object-cover"
            />
          )}
          <div>
            <p class="font-semibold">{article.author?.fullName}</p>
          <time datetime={article.publishedAt}>
  {new Date(article.publishedAt).toLocaleDateString('hu-HU')}
</time>
          </div>
        </div>
      </header>
      
 
      {article.featuredImage && (
        <StrapiImage 
          image={article.featuredImage} 
          class="w-full h-96 object-cover rounded-lg mb-8"
          alt={article.featuredImage.alternativeText}
        />
      )}
      
 
      <div class="prose prose-lg max-w-none" set:html={htmlContent} />
      
    </div>
  </article>
</BaseLayout>