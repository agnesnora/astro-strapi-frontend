---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getArticles } from '../../../lib/loader';
import StrapiImage from '../../../components/StrapiImage.astro';


const articlesData = await getArticles("hu");
const articles: any[] = articlesData.data || [];
const currentPath = Astro.url.pathname;
const locale = currentPath.startsWith('/en') ? 'en' : 'hu';
---

<BaseLayout locale={locale}>
  <section class="py-16">
    <div class="container mx-auto px-4">
      <h1 class="text-4xl font-bold mb-8">Blog</h1>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {articles.map((article) => (
         <a href={`/blog/${article.slug}`}>
            <article class="border rounded-lg overflow-hidden shadow-sm hover:shadow-md transition">
              {article.featuredImage && (
                <StrapiImage 
                  image={article.featuredImage} 
                  class="w-full h-48 object-cover"
                />
              )}
              <div class="p-4">
                <h2 class="text-xl font-semibold group-hover:text-blue-600">
                  {article.title}
                </h2>
                <p class="text-gray-600 mt-2">{article.description}</p>
                {article.author && (
                  <p class="text-sm text-gray-500 mt-4">
                    By {article.author.fullName}
                  </p>
                )}
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>